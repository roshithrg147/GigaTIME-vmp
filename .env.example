# ============================================================
# GigaTIME-vmp Environment Configuration
# ============================================================

# --- REQUIRED (container will NOT start without these) ---

# Google Gemini API key — must be set in Cloud Run environment variables
GEMINI_API_KEY=your-gemini-api-key-here


# --- OPTIONAL (safe defaults are provided) ---

# Gemini model to use for clinical interpretation
GEMINI_MODEL=gemini-2.5-flash

# SQLite database path — for local development only
# On Cloud Run, this should point to a mounted persistent volume or be
# replaced with a Cloud SQL / Firestore connection string.
DATABASE_URL=sqlite:///./gigatime_jobs.db

# Application environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# GigaTIME inference mode
# Values: MOCK | azure | hf | selfhosted
GIGATIME_MODEL_ENDPOINT=MOCK


# --- AZURE INFERENCE (optional, only needed if GIGATIME_MODEL_ENDPOINT=azure) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_WORKSPACE_NAME=


# --- HUGGINGFACE INFERENCE (optional, only needed if GIGATIME_MODEL_ENDPOINT=hf) ---
HF_API_TOKEN=
HF_GIGATIME_ENDPOINT_URL=
