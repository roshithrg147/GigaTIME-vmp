# ─── GigaTIME Model Endpoint ─────────────────────────────────────────────────
# Set to your Azure ML managed endpoint name.
# Set to MOCK to run fully offline without Azure credentials.
GIGATIME_MODEL_ENDPOINT=MOCK

# ─── Azure Identity ───────────────────────────────────────────────────────────
# DefaultAzureCredential will use these if set, otherwise falls back to
# managed identity (for Cloud Run) or az login (for local dev).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Azure ML workspace details (required by WorkspaceEndpointManager)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_WORKSPACE_NAME=

# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ─── Hugging Face (optional, for future HF provider) ─────────────────────────
HF_API_TOKEN=
HF_GIGATIME_ENDPOINT_URL=

# ─── App Config ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
