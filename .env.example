# Azure AI Foundry / GigaTIME Configuration
# The scoring endpoint for the GigaTIME model
AZURE_GIGATIME_ENDPOINT="https://your-resource-name.openai.azure.com/openai/deployments/gigatime/score"
# Your Azure API Key
AZURE_API_KEY="your_api_key_here"
# Azure API Version (e.g., 2024-02-15-preview)
AZURE_API_VERSION="2024-02-15-preview"

# MCP Server Configuration
MCP_SERVER_NAME="GigaTIME-McpServer"
MCP_SERVER_VERSION="0.1.0"

# Storage Configuration
# Local SQLite database for job persistence
DATABASE_URL="sqlite:///./gigatime_jobs.db"

# Logging & Environment
LOG_LEVEL="INFO"
ENVIRONMENT="development"

# Gemini Integration
# API Key for generating spatial architecture clinical summaries
GEMINI_API_KEY="your_gemini_api_key_here"
